---
layout: default
---
{% unless site.data.resume %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <article>
      <div class="cv">
        {% if page.cv_pdf %}
          <iframe
            src="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            style="width: 100%; height: 800px;"
            frameborder="0"
          ></iframe>
        {% endif %}
      </div>
    </article>
  </div>
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <article>
      <div class="cv">
        {% if page.cv_pdf %}
          <iframe
            src="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            style="width: 100%; height: 800px;"
            frameborder="0"
          ></iframe>
        {% endif %}
      </div>
    </article>
  </div>
{% endunless %}
